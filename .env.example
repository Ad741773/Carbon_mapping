# ── Flask core ─────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-jwt-secret-too
JWT_ACCESS_TOKEN_EXPIRES=86400       # seconds  (24 h)

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///ecotrace.db
# PostgreSQL (requires psycopg2): DATABASE_URL=postgresql://user:pw@host/db

# ── AI (optional) ──────────────────────────────────────────
GEMINI_API_KEY=                      # leave blank → rule-based engine
